# ---- RAG ------------------------------------------------------------------
# Selects the RagService implementation. "rag_bot" wires retrieval + grounded
# generation via the rag_bot adapter; "null" boots without RAG.
RAG_PROVIDER=rag_bot
DATA_ROOT=/mnt/data/rag_bot/data
DEFAULT_SOURCE_TYPE=faguquanji
RETRIEVAL_BACKEND=milvus         # milvus | lexical
RETRIEVAL_LIMIT=5
RERANK_ENABLED=false

# ---- Embedding service (TEI) — only used when RETRIEVAL_BACKEND=milvus ----
EMBEDDING_BASE_URL=http://localhost:8080
EMBEDDING_TRUNCATE=true

# ---- Milvus — only used when RETRIEVAL_BACKEND=milvus ---------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=langchain_demo
MILVUS_COLLECTION_PREFIX=rag_bot
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_TOKEN=
MILVUS_SECURE=false
MILVUS_TIMEOUT=30.0

# ---- Rerank service — only used when RERANK_ENABLED=true ------------------
RERANK_ENDPOINT=http://localhost:8081/rerank
RERANK_TOP_N=5
RERANK_CANDIDATE_K=10
RERANK_BATCH_SIZE=64
RERANK_TIMEOUT=120.0
RERANK_TRUNCATE_CHARS=0

# ---- Generation LLM (shared with rag_bot via rag_bot.llm_config.resolve) ---
# Pick a vendor alias, then supply {VENDOR}_BASE_URL/API_KEY/MODEL_NAME.
GEN_LLM=LOCAL5060
LOCAL5060_BASE_URL=http://localhost:8003/v1
LOCAL5060_API_KEY=not-needed
LOCAL5060_MODEL_NAME=qwen3-8B

# ---- Legacy LLM fields (deprecated — kept one release for rollback) -------
OPENAI_API_BASE=http://area51r5:8003/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=gpt-4o-mini

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3002

# Postgres (thread checkpointer)
POSTGRES_URI=postgresql://langgraph:langgraph@localhost:5434/langgraph

# Conversation limits
MAX_MESSAGE_WINDOW=20
MAX_THREADS_PER_USER=100

# App
APP_ENV=development
LOG_LEVEL=info

# Auth
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_ISSUER=https://accounts.google.com
GOOGLE_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
AUTH_JWKS_CACHE_TTL_SECONDS=3600
AUTH_ALLOWED_CLOCK_SKEW_SECONDS=30
# Logto OSS (self-hosted OIDC)
LOGTO_OIDC_ISSUER=http://localhost:3302/oidc
LOGTO_OIDC_JWKS_URL=http://localhost:3302/oidc/jwks
LOGTO_OIDC_AUDIENCE=https://api.myapp.local

AUTH_DEV_MODE=false
AUTH_DEV_ISSUER=https://dev.local
