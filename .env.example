# LLM (OpenAI-compatible endpoint)
OPENAI_API_BASE=http://area51r5:8003/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=gpt-4o-mini

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3002

# Postgres (thread checkpointer)
POSTGRES_URI=postgresql://langgraph:langgraph@localhost:5434/langgraph

# Conversation limits
MAX_MESSAGE_WINDOW=20
MAX_THREADS_PER_USER=100

# App
APP_ENV=development
LOG_LEVEL=info

# Auth
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_ISSUER=https://accounts.google.com
GOOGLE_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
AUTH_JWKS_CACHE_TTL_SECONDS=3600
AUTH_ALLOWED_CLOCK_SKEW_SECONDS=30
# Logto OSS (self-hosted OIDC)
LOGTO_OIDC_ISSUER=http://localhost:3302/oidc
LOGTO_OIDC_JWKS_URL=http://localhost:3302/oidc/jwks
LOGTO_OIDC_AUDIENCE=https://api.myapp.local

AUTH_DEV_MODE=false
AUTH_DEV_ISSUER=https://dev.local
