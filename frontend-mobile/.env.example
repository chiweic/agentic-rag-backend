# frontend-mobile env template. Copy to .env.local and fill in real values.
#
# IMPORTANT: NO QUOTES around any value below. python-dotenv (used by Next.js
# in dev) silently strips quotes, but `docker --env-file` (used by
# docker-compose for the prod container) passes them through literally —
# values like "sk-..." get sent to the consumer with the quotes embedded,
# which has bitten this stack before (Langfuse OTEL 401 from quoted
# LANGFUSE_SECRET_KEY, see docs/deploy.md). Same rule: KEY=value, no quotes,
# no inline `# comments` after the value.

# ---- Logto OIDC (shared with desktop frontend; same Client ID) ----
# In dev (LAN testing from a phone), use the dev-server LAN IP:
#   LOGTO_BASE_URL=http://192.168.50.253:3200
# In prod, use the Cloudflare-fronted hostname:
#   LOGTO_BASE_URL=https://m.changpt.org
# Whatever you set, the matching `${LOGTO_BASE_URL}/api/logto/sign-in-callback`
# must be registered as a Redirect URI on the Logto application (additive —
# don't touch existing entries for the desktop frontend).
LOGTO_ENDPOINT=https://auth.changpt.org
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=https://m.changpt.org
LOGTO_COOKIE_SECRET=
LOGTO_RESOURCE=https://api.myapp.local

# ---- Backend proxy target ----
# In dev on the host machine: http://localhost:8082 (backend container's
# published port). In the prod container, this is rewritten by the proxy
# route handler against host.docker.internal (see Dockerfile + compose).
LANGGRAPH_API_URL=http://host.docker.internal:8082
